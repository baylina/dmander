# LLM principal
# Valores soportados: openai, ollama, lmstudio
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=
LLM_API_KEY=

# Compatibilidad con la configuración antigua de OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# Embeddings semánticos
# Valores soportados: inherit, openai, ollama, lmstudio, disabled
EMBEDDING_PROVIDER=inherit
EMBEDDING_MODEL=
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=

# Reranker semántico
# Valores soportados: inherit, openai, ollama, lmstudio, disabled
RERANK_PROVIDER=inherit
RERANK_MODEL=
RERANK_BASE_URL=
RERANK_API_KEY=

# Ejemplos útiles:
# Ollama:
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen2.5:7b-instruct
# LLM_BASE_URL=http://127.0.0.1:11434/v1
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text
#
# LM Studio:
# LLM_PROVIDER=lmstudio
# LLM_MODEL=local-model
# LLM_BASE_URL=http://127.0.0.1:1234/v1
# EMBEDDING_PROVIDER=lmstudio

# Contrato maestro de normalización
DMANDER_MASTER_SCHEMA_PATH=/Users/coni/tmp/dmander/dmander_master_schema_v01.json

# Máximo de iteraciones de preguntas (opcional, por defecto 8)
MAX_ITERATIONS=8

# Token del bot de Telegram (obligatorio para modo bot)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# URL de conexión a PostgreSQL (obligatorio)
DATABASE_URL=postgresql://localhost:5432/dmander

# Sesiones web
SESSION_SECRET=change-me-with-a-long-random-secret
WEB_HOST=127.0.0.1
WEB_PORT=8000
APP_BASE_URL=http://127.0.0.1:8000

# Email transaccional (alta de cuenta, reset de contraseña)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=doselevadoatres@gmail.com
SMTP_PASSWORD=
SMTP_FROM=doselevadoatres@gmail.com

# Depuración de normalización
DEBUG_NORMALIZATION=false
SHOW_NORMALIZED_JSON=false

# OAuth social opcional para la web
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
META_CLIENT_ID=
META_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
