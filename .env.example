# API key de OpenAI (obligatorio)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo a usar (opcional, por defecto gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Contrato maestro de normalización
DMANDER_MASTER_SCHEMA_PATH=/Users/coni/tmp/dmander/dmander_master_schema_v01.json

# Máximo de iteraciones de preguntas (opcional, por defecto 8)
MAX_ITERATIONS=8

# Token del bot de Telegram (obligatorio para modo bot)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# URL de conexión a PostgreSQL (obligatorio)
DATABASE_URL=postgresql://localhost:5432/dmander

# Sesiones web
SESSION_SECRET=change-me-with-a-long-random-secret
WEB_HOST=127.0.0.1
WEB_PORT=8000

# Depuración de normalización
DEBUG_NORMALIZATION=false
SHOW_NORMALIZED_JSON=false

# OAuth social opcional para la web
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
META_CLIENT_ID=
META_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
